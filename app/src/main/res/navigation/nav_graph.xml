<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_map">

    <fragment
        android:id="@+id/nav_map"
        android:name="com.example.guet_map.ui.map.MapFragment"
        android:label="地图" />

    <fragment
        android:id="@+id/nav_explore"
        android:name="com.example.guet_map.ui.explore.ExploreFragment"
        android:label="探索" />

    <fragment
        android:id="@+id/nav_favorites"
        android:name="com.example.guet_map.ui.favorites.FavoritesFragment"
        android:label="收藏" />

    <fragment
        android:id="@+id/nav_contribute"
        android:name="com.example.guet_map.ui.contribute.ContributeFragment"
        android:label="添加" />

    <fragment
        android:id="@+id/nav_notifications"
        android:name="com.example.guet_map.ui.notifications.NotificationsFragment"
        android:label="通知" />

    <fragment
        android:id="@+id/nav_login"
        android:name="com.example.guet_map.ui.login.LoginFragment"
        android:label="登录" />

    <fragment
        android:id="@+id/nav_weather_detail"
        android:name="com.example.guet_map.module.social.ui.weather.WeatherDetailFragment"
        android:label="天气预报详情" />

    <fragment
        android:id="@+id/nav_api_key_settings"
        android:name="com.example.guet_map.module.ai.ui.settings.ApiKeySettingsFragment"
        android:label="AI 服务配置" />

    <!-- 个人中心 -->
    <fragment
        android:id="@+id/nav_profile"
        android:name="com.example.guet_map.ui.profile.ProfileFragment"
        android:label="个人中心" />

    <!-- 好友列表 -->
    <fragment
        android:id="@+id/nav_friends"
        android:name="com.example.guet_map.ui.friends.FriendsFragment"
        android:label="好友列表" />

    <!-- 添加好友 -->
    <fragment
        android:id="@+id/nav_add_friend"
        android:name="com.example.guet_map.ui.friends.AddFriendFragment"
        android:label="添加好友" />

    <!-- 聊天 -->
    <fragment
        android:id="@+id/nav_chat"
        android:name="com.example.guet_map.ui.chat.ChatFragment"
        android:label="聊天">
        <argument
            android:name="friendId"
            app:argType="long"
            android:defaultValue="0L" />
        <argument
            android:name="friendName"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <!-- 好友定位 -->
    <fragment
        android:id="@+id/nav_friend_location"
        android:name="com.example.guet_map.ui.friends.FriendLocationFragment"
        android:label="好友定位" />

    <!-- 好友请求 -->
    <fragment
        android:id="@+id/nav_friend_requests"
        android:name="com.example.guet_map.ui.friends.FriendRequestsFragment"
        android:label="好友请求" />

    <!-- 我的收藏 -->
    <fragment
        android:id="@+id/nav_favorites"
        android:name="com.example.guet_map.ui.profile.FavoritesFragment"
        android:label="我的收藏" />

</navigation>
