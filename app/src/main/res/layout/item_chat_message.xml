<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="8dp"
    android:paddingVertical="4dp">

    <!-- 接收的消息 -->
    <LinearLayout
        android:id="@+id/layoutReceived"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="horizontal"
        android:gravity="top">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivAvatarReceived"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_avatar" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="48dp">

            <TextView
                android:id="@+id/tvMessageReceived"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_bubble_received"
                android:padding="12dp"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="15sp"
                android:maxWidth="260dp" />

            <TextView
                android:id="@+id/tvTimeReceived"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginStart="4dp"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 发送的消息 -->
    <LinearLayout
        android:id="@+id/layoutSent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:orientation="horizontal"
        android:gravity="top"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="48dp"
            android:layout_marginEnd="8dp"
            android:gravity="end">

            <TextView
                android:id="@+id/tvMessageSent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_bubble_sent"
                android:padding="12dp"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:maxWidth="260dp" />

            <TextView
                android:id="@+id/tvTimeSent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="4dp"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="11sp" />
        </LinearLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivAvatarSent"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_avatar" />
    </LinearLayout>

</FrameLayout>
